# .coveragerc
[run]
source = .
omit =
    tests/*
    *paradata.py
    para_licenses.py
    setup.py

[report]
# Ratchet: set below the measured fast-lane baseline (2026-07-16, issue atrium-project#10)
fail_under = 42
exclude_lines =
    pragma: no cover
    def __repr__
    if self\.debug
    raise AssertionError
    raise NotImplementedError
    if 0:
    if __name__ == .__main__.: